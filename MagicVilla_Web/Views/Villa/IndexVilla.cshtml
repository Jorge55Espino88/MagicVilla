@model IEnumerable<MagicVilla_Web.Models.Dto.VillaDTO>

<hr />
<div class="container p-4 border">
    <div class="row pb-2">
        <div class="col">
            <h1 class="text-primary">Villa List</h1>
        </div>
        <div class="col text-end pt-1">
            <a asp-controller="Villa" asp-action="CreateVilla" class="btn btn-outline-primary"><i class="bi bi-plus"></i> Create new Villa</a>
        </div>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Occupancy</th>
            <th>Price</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var villa in Model)
        {
            <tr>
                <td>@villa.Name</td>
                <td>@villa.Occupancy</td>
                <td>@(villa.Rate.ToString("c"))</td>
                <td>
                    <a asp-controller="Villa" asp-action="EditVilla" 
                    class="btn btn-success"><i class="bi bi-pencil-square"></i></a>

                    <a asp-controller="Villa" asp-action="DeleteVilla" class="btn btn-danger"><i class="bi bi-trash-fill"></i></a>
                </td>
            </tr>
        }
    </tbody>
</table>
